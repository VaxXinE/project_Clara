FROM python:3.14-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy \
    PATH="/app/clara-backend/.venv/bin:${PATH}"

WORKDIR /app/clara-backend

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

COPY clara-backend/pyproject.toml clara-backend/uv.lock clara-backend/README.md ./

RUN uv sync --frozen --no-dev

COPY clara-backend/ ./
COPY clara_knowledge/ /app/clara_knowledge/
COPY infra/docker/ /app/infra/docker/

EXPOSE 8000
