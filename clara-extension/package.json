{
  "name": "clara-extension",
  "displayName": "Clara Extension",
  "version": "0.0.95",
  "description": "Browser extension Clara untuk membaca chat aktif WhatsApp Web dengan sinkronisasi snapshot yang lebih stabil.",
  "author": "newsmaker.id",
  "scripts": {
    "dev": "concurrently \"node scripts/plasmo-cli.mjs dev\" \"node server/openai-proxy.mjs\"",
    "build": "node scripts/plasmo-cli.mjs build",
    "package": "node scripts/plasmo-cli.mjs package",
    "proxy": "node server/openai-proxy.mjs"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "svgo": "^3.3.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "concurrently": "^9.2.1",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "cookies",
      "declarativeNetRequest",
      "sidePanel",
      "storage",
      "tabs",
      "scripting"
    ],
    "host_permissions": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://chat.openai.com/*",
      "https://chatgpt.com/*",
      "https://www.instagram.com/*",
      "https://www.tiktok.com/*",
      "https://web.whatsapp.com/*",
      "https://clara.newsmaker.id/*"
    ]
  }
}
